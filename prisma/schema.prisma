generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CLIENT)
  createdAt    DateTime @default(now())

  // Fields only relevant when role = CLIENT — shared across all of a
  // client's businesses, since it's one coaching relationship / one call.
  nextMeetingAt DateTime?
  zoomLink      String?
  archivedAt    DateTime?
  ninetyDayPlan String?   @db.Text

  // Tracks which nextMeetingAt value a reminder email was last sent for,
  // so the daily cron job doesn't send duplicate reminders for the same
  // session.
  reminderSentForMeetingAt DateTime?

  // A warm, personal note written directly TO the client (not the coach
  // briefing) — refreshed automatically alongside the AI briefing.
  clientMessage          String?   @db.Text
  clientMessageUpdatedAt DateTime?

  businesses     Business[]
  notesAsClient  Note[]     @relation("ClientNotes")
  notesAsAuthor  Note[]     @relation("AuthorNotes")
  wins           Win[]
  resources      Resource[]
  homeworkItems  HomeworkItem[]
  sessions       Session[]
  plan           Plan?
  sentMessages   Message[]  @relation("SentMessages")
  threadMessages Message[]  @relation("ClientThread")
}

// One of a client's businesses/ventures. Most clients have exactly one —
// the UI only shows a business switcher when a client has more than one.
// Metrics and the AI briefing are scoped per business, since progress on
// separate ventures shouldn't be blended together. The 90-day plan is
// shared at the client level (see User.ninetyDayPlan) since most coaches
// think of it as one overall plan for the relationship.
model Business {
  id               String    @id @default(cuid())
  name             String
  insight          String?   @db.Text
  insightUpdatedAt DateTime?
  createdAt        DateTime  @default(now())

  client   User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  metrics Metric[]
}

model Note {
  id        String   @id @default(cuid())
  content   String
  // Private notes never appear on the client's own dashboard — for the
  // coach's internal thinking only.
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())

  client   User   @relation("ClientNotes", fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  author   User   @relation("AuthorNotes", fields: [authorId], references: [id])
  authorId String
}

model Win {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  client   User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  url         String?
  description String?
  createdAt   DateTime @default(now())

  client   User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String
}

// A structured record of an actual coaching call — separate from the
// freeform Notes feed, since a call summary reads much better broken
// into date/duration/summary than pasted as one flat block of text.
model Session {
  id              String   @id @default(cuid())
  sessionNumber   Int
  date            DateTime @default(now())
  durationMinutes Int?
  summary         String   @db.Text
  createdAt       DateTime @default(now())

  client   User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String
}

// Small between-session commitments — either the coach or the client can
// add these, and either side can check them off.
model HomeworkItem {
  id          String    @id @default(cuid())
  title       String
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  client   User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String
}

// Every message belongs to exactly one client's thread (shared across all
// of that client's businesses). The sender may be that client, or one of
// the coaches (Michael / Ben) replying into it.
model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  sender   User   @relation("SentMessages", fields: [senderId], references: [id])
  senderId String

  client   User   @relation("ClientThread", fields: [clientId], references: [id], onDelete: Cascade)
  clientId String
}

// A metric a specific business tracks over time, e.g. "Weight", "Weekly
// revenue". Each metric has many data points.
model Metric {
  id        String   @id @default(cuid())
  name      String
  unit      String?
  target    Float?
  createdAt DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId String

  entries MetricEntry[]
}

model MetricEntry {
  id         String   @id @default(cuid())
  value      Float
  recordedAt DateTime @default(now())

  metric   Metric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  metricId String
}

// Lightweight abuse protection — records an event per attempt (failed
// login, intake submission) keyed by email or IP, so we can count recent
// attempts within a time window without needing an external service.
model RateLimitEvent {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

// A structured quarterly success plan for a client — one document that
// contains a section per business, each with its own theme, personal
// recommendations, projects (outcome/approach/measures/timeline), and KPIs.
// Replaces the old plain-text ninetyDayPlan when present.
model Plan {
  id           String    @id @default(cuid())
  quarterLabel String
  startDate    DateTime?
  endDate      DateTime?
  advisorName  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  client   User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String @unique

  sections PlanSection[]
}

model PlanSection {
  id               String  @id @default(cuid())
  businessName     String
  theme            String?
  themeDescription String? @db.Text
  // Recommendations stored as newline-separated "Title: description" lines
  // — simple to edit in a textarea, simple to render as a list.
  recommendations  String? @db.Text
  order            Int     @default(0)

  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId String

  projects PlanProject[]
  kpis     PlanKpi[]
}

model PlanProject {
  id          String  @id @default(cuid())
  name        String
  outcome     String  @db.Text
  // Bullet lists stored as newline-separated text — one line per bullet.
  keyApproach String  @db.Text
  measures    String  @db.Text
  month1Label String?
  month2Label String?
  month3Label String?
  order       Int     @default(0)

  section   PlanSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId String
}

model PlanKpi {
  id    String  @id @default(cuid())
  name  String
  value String?
  order Int     @default(0)

  section   PlanSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId String
}
