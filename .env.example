# Postgres connection string. Works with Neon, Supabase, Railway, RDS, etc.
DATABASE_URL="postgresql://user:password@host:5432/coaching_hub?sslmode=require"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"

# The public URL this app is deployed at (used by NextAuth for callbacks)
NEXTAUTH_URL="http://localhost:3000"
